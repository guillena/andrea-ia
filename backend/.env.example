# ─────────────────────────────────────────────────────────────
# ANDREA — Variables de entorno (Backend)
# Copiar a .env y completar con valores reales
# NUNCA commitear .env con valores reales
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL="postgresql://andrea:andrea_secret@localhost:5432/andrea_db?schema=public"
POSTGRES_USER=andrea
POSTGRES_PASSWORD=andrea_secret
POSTGRES_DB=andrea_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── HMAC para firma de tokens de evaluación ───────────────────
EVAL_TOKEN_SECRET=change_me_to_eval_token_secret_min_32_chars

# ── Azure AI Speech (STT + TTS) ───────────────────────────────
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
# Voz TTS (opciones: es-MX-DaliaNeural, es-AR-TomasNeural)
AZURE_TTS_VOICE=es-MX-DaliaNeural
# Idioma STT
AZURE_STT_LANGUAGE=es-MX

# ── Azure OpenAI (LLM) ────────────────────────────────────────
AZURE_OPENAI_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
# Deployment names en Azure OpenAI
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini

# ── Railway Buckets (Storage S3-compatible) ───────────────────
STORAGE_ENDPOINT=https://your-bucket.up.railway.app
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=your_railway_bucket_access_key
STORAGE_SECRET_KEY=your_railway_bucket_secret_key
STORAGE_BUCKET_NAME=andrea-files
STORAGE_PUBLIC_URL=https://your-bucket.up.railway.app

# ── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@andrea.app
EMAIL_FROM_NAME=ANDREA

# ── Evaluación ───────────────────────────────────────────────
EVAL_LINK_DEFAULT_EXPIRY_DAYS=7
EVAL_SESSION_MAX_DURATION_MINUTES=20

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_EVAL_PER_SECOND=5
RATE_LIMIT_API_PER_SECOND=100
